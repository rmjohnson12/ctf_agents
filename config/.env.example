# Example environment variables configuration
# Copy this file to .env and fill in your actual values

# System Settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# API Keys (External Services)
OPENAI_API_KEY=your_openai_api_key_here
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
SHODAN_API_KEY=your_shodan_api_key_here
DEHASHED_API_KEY=your_dehashed_api_key_here

# Burp Suite
BURP_API_KEY=your_burp_api_key_here

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ctf_agents
DB_USER=ctf_user
DB_PASSWORD=your_secure_password_here

# Redis Configuration (if using)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ Configuration (if using)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Security Settings
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here

# CTF Platform Integration (Optional)
CTFD_URL=https://your-ctf-instance.com
CTFD_TOKEN=your_ctfd_token_here

# Notification Settings (Optional)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Resource Limits
MAX_CONCURRENT_CHALLENGES=5
AGENT_TIMEOUT_SECONDS=1800
TOOL_TIMEOUT_SECONDS=600

# Feature Flags
ENABLE_CACHING=true
ENABLE_LEARNING=true
ENABLE_PARALLEL_SOLVING=true
ENABLE_SANDBOXING=true
